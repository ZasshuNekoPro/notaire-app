# ============================================================
# NOTAIRE APP — Configuration environnement
# Copier ce fichier en .env et remplir les valeurs
# Ne jamais committer .env !
# ============================================================

# ------------------------------------------------------------
# 🤖 CONFIGURATION IA
# ------------------------------------------------------------
# Provider actif : anthropic | openai | ollama | custom
AI_PROVIDER=anthropic

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-VOTRE_CLE_ICI
AI_MODEL=claude-sonnet-4-20250514

# OpenAI
OPENAI_API_KEY=sk-VOTRE_CLE_ICI
OPENAI_BASE_URL=https://api.openai.com/v1

# Ollama (IA locale — aucune clé requise)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b

# Provider custom (LM Studio, Groq, vLLM, etc.)
CUSTOM_AI_BASE_URL=http://localhost:1234/v1
CUSTOM_AI_API_KEY=not-required
CUSTOM_AI_MODEL=local-model

# Paramètres communs
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=4096

# ------------------------------------------------------------
# 🗄️ BASE DE DONNÉES
# ------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=notaire_app
POSTGRES_USER=notaire
POSTGRES_PASSWORD=changeme_en_production
DATABASE_URL=postgresql+asyncpg://notaire:changeme@localhost:5432/notaire_app

# ------------------------------------------------------------
# 📦 CACHE REDIS
# ------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_TTL_SECONDS=3600

# ------------------------------------------------------------
# 🌐 API BACKEND
# ------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=changeme_secret_key_minimum_32_caracteres
API_DEBUG=true
API_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ------------------------------------------------------------
# 🖥️ FRONTEND
# ------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Notaire App
NEXT_PUBLIC_APP_VERSION=0.1.0

# ------------------------------------------------------------
# 🔐 AUTHENTIFICATION
# ------------------------------------------------------------
JWT_SECRET=changeme_jwt_secret_very_long_string_minimum_32_chars
JWT_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# ------------------------------------------------------------
# ✍️ SIGNATURE ÉLECTRONIQUE
# ------------------------------------------------------------
SIGNATURE_PROVIDER=simulee
YOUSIGN_API_KEY=
YOUSIGN_WEBHOOK_SECRET=

# ------------------------------------------------------------
# 📡 DONNÉES OPEN DATA
# ------------------------------------------------------------
DVF_DATA_DIR=./data/dvf
DVF_DEPARTMENTS=75,92,93,94
BAN_API_URL=https://api-adresse.data.gouv.fr
LEGIFRANCE_CLIENT_ID=
LEGIFRANCE_CLIENT_SECRET=

# ------------------------------------------------------------
# 📧 NOTIFICATIONS
# ------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre@email.com
SMTP_PASSWORD=votre_mot_de_passe_app
EMAIL_FROM=noreply@notaire-app.fr

# ------------------------------------------------------------
# 📊 MONITORING
# ------------------------------------------------------------
SENTRY_DSN=
LOG_LEVEL=INFO
